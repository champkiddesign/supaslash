{
  "name": "supaslash",
  "productName": "SupaSlash",
  "version": "1.0.10",
  "description": "A simple floating to-do timer for macOS",
  "main": "main.js",
  "scripts": {
    "start": "env -u ELECTRON_RUN_AS_NODE electron-forge start",
    "dev": "env -u ELECTRON_RUN_AS_NODE electron-forge start",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "make:local": "env -u APPLE_ID -u APPLE_APP_SPECIFIC_PASSWORD -u APPLE_TEAM_ID -u APPLE_SIGNING_IDENTITY SUPASLASH_LOCAL_BUILD=1 electron-forge make",
    "make:release": "set -a && [ -f .env ] && . ./.env; set +a && electron-forge make",
    "prepare:local-update": "bash scripts/prepare-local-update.sh",
    "update-server": "node scripts/local-update-server.js",
    "publish:release": "set -a && [ -f .env ] && . ./.env; set +a && export GITHUB_TOKEN=\"${GITHUB_TOKEN:-$GH_TOKEN}\" && electron-forge publish",
    "build-icon": "bash scripts/build-icon.sh"
  },
  "keywords": [
    "todo",
    "timer",
    "productivity"
  ],
  "author": "champkiddesign",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/champkiddesign/supaslash.git"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.8.1",
    "@electron-forge/maker-dmg": "^7.8.1",
    "@electron-forge/maker-zip": "^7.8.1",
    "@electron-forge/plugin-auto-unpack-natives": "^7.8.1",
    "@electron-forge/plugin-fuses": "^7.8.1",
    "@electron-forge/publisher-github": "^7.11.2",
    "@electron/fuses": "^1.8.0",
    "electron": "^28.3.3"
  },
  "dependencies": {
    "electron-updater": "^6.8.9"
  }
}
