APPLE_ID=you@example.com
APPLE_APP_SPECIFIC_PASSWORD=xxxx-xxxx-xxxx-xxxx
APPLE_TEAM_ID=XXXXXXXXXX
APPLE_SIGNING_IDENTITY="Developer ID Application: Your Name (TEAMID)"
GH_TOKEN=ghp_your_github_personal_access_token
# electron-forge reads GITHUB_TOKEN; GH_TOKEN also works via publish:release script

# Optional purchase checkout URL (Paddle or other). Leave empty to disable Purchase.
# SUPASLASH_CHECKOUT_URL=https://your-checkout-url.example

# Local dev only (npm start / unpackaged builds): activate with this key in the License modal
# License key: SUPASLASH-DEV-LOCAL-TEST
# Email: any value (e.g. dev@localhost)

# Beta testers (signed/packaged builds): share this key in the License modal
# License key: SUPASLASH-BETA-ACCESS
# Email: any value (e.g. their email)
# Optional override: SUPASLASH_BETA_LICENSE_KEY=your-custom-beta-key
