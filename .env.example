LEMONSQUEEZY_STORE_ID=0
LEMONSQUEEZY_PRODUCT_ID=0
LEMONSQUEEZY_VARIANT_IDS=0

# Local dev only (npm start / unpackaged builds): activate with this key in the License modal
# License key: SUPASLASH-DEV-LOCAL-TEST
# Email: any value (e.g. dev@localhost)
